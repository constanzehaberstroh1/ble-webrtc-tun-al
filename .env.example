# =============================================================================
# BLE WebRTC Tunnel - Environment Configuration
# =============================================================================

# --- Role: "client" or "server" ---
ROLE=client

# --- LiveKit / Bale Signaling ---
# WebSocket URL for LiveKit signaling (extract ICE/TURN credentials)
LIVEKIT_WS_URL=wss://meet-gwbm6.ble.ir/rtc
LIVEKIT_ACCESS_TOKEN=YOUR_ACCESS_TOKEN_HERE

# --- ICE / TURN Servers ---
# Primary TURN server (TURNS over TLS on port 443 - looks like HTTPS)
TURN_SERVER_PRIMARY=turns:meet-turn.ble.ir:443?transport=tcp
# Secondary TURN server
TURN_SERVER_SECONDARY=turn:2.189.68.97:3478?transport=tcp
# STUN servers
STUN_SERVER_PRIMARY=stun:2.189.68.115:443
STUN_SERVER_SECONDARY=stun:stun.l.google.com:19302

# TURN credentials (extracted from LiveKit signaling)
TURN_USERNAME=
TURN_CREDENTIAL=

# --- TUN Interface ---
# Client: 10.0.0.2, Server: 10.0.0.1
TUN_IP=10.0.0.2
TUN_MASK=255.255.255.0
TUN_MTU=1400
TUN_NAME=tun-ble

# --- Signaling Server (for SDP exchange) ---
# Server address that client connects to for SDP exchange
SIGNAL_SERVER_ADDR=YOUR_SERVER_PUBLIC_IP:8080

# --- Admin Panel ---
# Used for both the admin panel login AND the sync worker auth to the server.
# Each user should set their own credentials here.
ADMIN_LISTEN_ADDR=:8080
ADMIN_USERNAME=salman
ADMIN_PASSWORD=Salman136517

# --- Obfuscation (Anti-DPI) ---
# Shared secret for ChaCha20-Poly1305 payload obfuscation.
# MUST be identical on both client and server.
# If empty, traffic flows without encryption (DPI-visible).
OBFUSCATION_SECRET=

# --- Spatial Multi-Tracking Camouflage ---
# Number of Opus audio tracks to publish per session.  Data is striped
# round-robin across N tracks so each individual track maintains a low,
# voice-like bandwidth profile.  Default 3.  Set to 1 to disable multi-track.
BLE_TUNNEL_TRACKS=3

# --- Logging ---
LOG_LEVEL=info
